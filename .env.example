# YourBot status_service — example .env
# Copy to /etc/status/.env on the Ubuntu host (chmod 600).

# Probe configuration
PROBE_BASE_URL=https://yourbot.gg
PROBE_INTERVAL_SECONDS=60

# Storage
DB_PATH=/data/status.db

# Web server
HOST=0.0.0.0
PORT=8081

# Optional: Discord bot probe (skipped if blank). Use a token with `identify` scope only.
DISCORD_BOT_TOKEN=

# Discord webhook alerts (skipped if blank)
ALERT_DISCORD_WEBHOOK_URL=
ALERT_THRESHOLD_MIN=3
ALERT_COOLDOWN_MIN=15

# External heartbeat (skipped if blank). e.g. https://hc-ping.com/<uuid>
HEARTBEAT_PING_URL=

# Manual announcements admin auth — generate with: openssl rand -hex 32
ADMIN_HMAC_SECRET=

# One-time bootstrap token for the first /admin owner account.
# Visit /admin/setup?token=<this> while no owner exists; ignored afterward.
ADMIN_BOOTSTRAP_TOKEN=

# SLA target for the header line
SLA_TARGET_PCT=99.9

# SSL probe early-warning thresholds (days)
RR_SSL_WARN_DAYS=14
RR_SSL_CRITICAL_DAYS=3

# Backups — Litestream hot replication to Cloudflare R2 (S3-compatible)
BACKUP_ENABLED=1
LITESTREAM_REPLICA_URL=s3://mmo-maid-status-backups/status.db?endpoint=https://<account-id>.r2.cloudflarestorage.com&region=auto&force-path-style=true
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=

# Cold snapshots via scripts/backup.sh
RCLONE_REMOTE=r2
BACKUP_BUCKET=mmo-maid-status-backups

# Brand
BRAND_DISCORD_INVITE=https://discord.gg/yourbot
BRAND_BOT_AVATAR_URL=
BRAND_GITHUB_URL=
BRAND_LOGO_URL=/static/yourbot-logo.png
MAIN_SITE_URL=https://yourbot.gg

# Public URL of this status page (alert embeds + feed links) and badge label
STATUS_PUBLIC_URL=https://status.yourbot.work
BADGE_LABEL=yourbot
